#: ../../../migrating.rst:577
msgid "They have :attr:`~Permissions.read_message_history` permission in it."
msgstr ""

#: ../../../migrating.rst:578
msgid ""
"They have :attr:`~Permissions.add_reactions` permission in it or the message "
"already has that emoji reaction."
msgstr ""

#: ../../../migrating.rst:584
msgid ""
"A guild member can react with an emoji to messages in a public thread if:"
msgstr ""

#: ../../../migrating.rst:581 ../../../migrating.rst:587
msgid ""
"They have :attr:`~Permissions.read_message_history` permission in its parent "
"channel."
msgstr ""

#: ../../../migrating.rst:582 ../../../migrating.rst:588
msgid ""
"They have :attr:`~Permissions.add_reactions` permission in its parent "
"channel or the message already has that emoji reaction."
