#: ../../../migrating.rst:273
msgid "Quick example for asynchronous webhooks:"
msgstr ""

#: ../../../migrating.rst:275
msgid ""
"# before\n"
"async with aiohttp.ClientSession() as session:\n"
"    webhook = discord.Webhook.from_url('url-here', adapter=discord."
