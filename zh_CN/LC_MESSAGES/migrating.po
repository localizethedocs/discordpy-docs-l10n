"    await webhook.send('Hello World', username='Foo')\n"
"\n"
"# after\n"
"async with aiohttp.ClientSession() as session:\n"
"    webhook = discord.Webhook.from_url('url-here', session=session)\n"
"    await webhook.send('Hello World', username='Foo')"
msgstr ""

