msgid "Command Extension Changes"
msgstr ""

#: ../../../migrating.rst:1302
msgid "Extension and Cog Loading / Unloading is Now Asynchronous"
msgstr ""

#: ../../../migrating.rst:1304
msgid ""
"As an extension to the :ref:`asyncio changes "
"<migrating_2_0_client_async_setup>` the loading and unloading of extensions "
"and cogs is now asynchronous."
msgstr ""

#: ../../../migrating.rst:1306
msgid "To accommodate this, the following changes have been made:"
msgstr ""

#: ../../../migrating.rst:1308
msgid ""
"The ``setup`` and ``teardown`` functions in extensions must now be "
"coroutines."
msgstr ""

#: ../../../migrating.rst:1309
msgid ":meth:`ext.commands.Bot.load_extension` must now be awaited."
msgstr ""

#: ../../../migrating.rst:1310
msgid ":meth:`ext.commands.Bot.unload_extension` must now be awaited."
msgstr ""

#: ../../../migrating.rst:1311
msgid ":meth:`ext.commands.Bot.reload_extension` must now be awaited."
msgstr ""

#: ../../../migrating.rst:1312
msgid ":meth:`ext.commands.Bot.add_cog` must now be awaited."
msgstr ""

#: ../../../migrating.rst:1313
msgid ":meth:`ext.commands.Bot.remove_cog` must now be awaited."
msgstr ""

#: ../../../migrating.rst:1315
msgid "Quick example of an extension setup function:"
msgstr ""

#: ../../../migrating.rst:1317
msgid ""
"# before\n"
"def setup(bot):\n"
"    bot.add_cog(MyCog(bot))\n"
"\n"
"# after\n"
"async def setup(bot):\n"
"    await bot.add_cog(MyCog(bot))"
msgstr ""

#: ../../../migrating.rst:1327
msgid "Quick example of loading an extension:"
msgstr ""

#: ../../../migrating.rst:1329
msgid ""
"# before\n"
"bot.load_extension('my_extension')\n"
"\n"
"# after using setup_hook\n"
"class MyBot(commands.Bot):\n"
"    async def setup_hook(self):\n"
"        await self.load_extension('my_extension')\n"
"\n"
"# after using async_with\n"
"async def main():\n"
"    async with bot:\n"
"        await bot.load_extension('my_extension')\n"
"        await bot.start(TOKEN)\n"
"\n"
"asyncio.run(main())"
msgstr ""

#: ../../../migrating.rst:1349
msgid "Converters Are Now Generic Runtime Protocols"
msgstr ""

#: ../../../migrating.rst:1351
msgid ""
