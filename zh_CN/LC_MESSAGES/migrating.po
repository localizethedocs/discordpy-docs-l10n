msgstr ""

#: ../../../migrating.rst:811
msgid "``AsyncIterator.chunk()``"
msgstr ""

#: ../../../migrating.rst:813
msgid ""
"# before\n"
"async for leader, *users in reaction.users().chunk(3):\n"
