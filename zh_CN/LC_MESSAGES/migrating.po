msgstr ""

#: ../../../migrating.rst:823
msgid "``AsyncIterator.map()``"
msgstr ""

#: ../../../migrating.rst:825
msgid ""
"# before\n"
"content_of_messages = []\n"
"async for content in channel.history().map(lambda m: m.content):\n"
