"RequestsWebhookAdapter())\n"
"webhook.send('Hello World', username='Foo')\n"
"\n"
"# after\n"
"webhook = discord.SyncWebhook.partial(123456, 'token-here')\n"
"webhook.send('Hello World', username='Foo')"
msgstr ""

