#: ../../../migrating.rst:1358
msgid ""
"# before\n"
"class SomeConverterMeta(type):\n"
"    ...\n"
"\n"
"class SomeConverter(commands.Converter, metaclass=SomeConverterMeta):\n"
"    ...\n"
"\n"
"# after\n"
"class SomeConverterMeta(type(commands.Converter)):\n"
"    ...\n"
"\n"
"class SomeConverter(commands.Converter, metaclass=SomeConverterMeta):\n"
"    ..."
msgstr ""

#: ../../../migrating.rst:1374
