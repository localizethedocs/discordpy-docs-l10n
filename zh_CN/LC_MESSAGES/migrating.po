"\n"
"# after\n"
"content_of_messages = [message.content async for message in channel."
"history()]"
msgstr ""

#: ../../../migrating.rst:835
msgid "``AsyncIterator.filter()``"
msgstr ""

#: ../../../migrating.rst:837
msgid ""
"def predicate(message):\n"
"    return not message.author.bot\n"
"\n"
"# before\n"
"user_messages = []\n"
"async for message in channel.history().filter(lambda m: not m.author.bot):\n"
"    user_messages.append(message)\n"
"\n"
"# after\n"
"user_messages = [message async for message in channel.history() if not m."
"author.bot]"
