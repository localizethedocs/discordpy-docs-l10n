"see the `changes <http://aiohttp.readthedocs.io/en/stable/changes."
"html#rc1-2017-03-15>`_ and the :doc:`aio:migration_to_2xx` pages for details "
"on the breaking changes in :doc:`aiohttp <aio:index>`."
msgstr ""

#: ../../../migrating_to_v1.rst:713
msgid ""
"Of the most significant for common users is the removal of helper functions "
"such as:"
msgstr ""

#: ../../../migrating_to_v1.rst:715
msgid "``aiohttp.get``"
msgstr ""

#: ../../../migrating_to_v1.rst:716
msgid "``aiohttp.post``"
msgstr ""

#: ../../../migrating_to_v1.rst:717
msgid "``aiohttp.delete``"
msgstr ""

#: ../../../migrating_to_v1.rst:718
msgid "``aiohttp.patch``"
msgstr ""

#: ../../../migrating_to_v1.rst:719
msgid "``aiohttp.head``"
msgstr ""

#: ../../../migrating_to_v1.rst:720
msgid "``aiohttp.put``"
msgstr ""

#: ../../../migrating_to_v1.rst:721
msgid "``aiohttp.request``"
msgstr ""

#: ../../../migrating_to_v1.rst:723
msgid "It is recommended that you create a session instead: ::"
msgstr ""

#: ../../../migrating_to_v1.rst:725
msgid ""
"async with aiohttp.ClientSession() as sess:\n"
"    async with sess.get('url') as resp:\n"
"        # work with resp"
msgstr ""

#: ../../../migrating_to_v1.rst:729
